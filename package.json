  "scripts": {
    "build": "prisma generate && yarn openapi:generate && next build",
    "clean": "rm -rf node_modules .next tsconfig.tsbuildinfo generated && yarn install && prisma generate",
    "db:clean-local": "bash ee/scripts/clean-local-db.sh",
    "db:get-user-stats": "yarn db:use-live-data && tsx ee/scripts/get-user-stats.ts",
    "db:reseed": "bash ee/scripts/reseed-db.sh",
    "db:reset": "bash ee/scripts/reset-db.sh",
    "db:use-live-data": "bash ee/scripts/use-live-data.sh",
    "dev": "prisma generate && yarn openapi:generate && next dev --turbopack -p 4000",
    "dev:fly": "bash ee/scripts/dev-fly.sh",
    "email:dev": "email dev --dir components/emails",
    "lint": "eslint . --ext .ts,.tsx,.json,.jsonc,.json5 -c .eslintrc.json --fix",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "start": "next start -p 4000",
    "templates:sync-openclaw": "bash ee/scripts/sync-openclaw-templates.sh",
    "templates:sync-orthogonal": "bash ee/scripts/sync-orthogonal-skill.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "vercel-build": "prisma generate && prisma migrate deploy && yarn openapi:generate && next build && bash ee/scripts/fly-deploy-if-needed.sh",
    "vercel-preview-build": "prisma generate && yarn db:reset && yarn openapi:generate && next build && bash ee/scripts/fly-deploy-if-needed.sh --reset",
    "webhook-deliveries:run": "bash ee/scripts/run-webhook-delivery-cron.sh"
